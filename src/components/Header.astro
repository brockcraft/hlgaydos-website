---
const navItems = [
  {
    label: 'Writing',
    children: [
      { label: 'Books',   href: '/books' },
      { label: 'Essays',  href: '/essays' },
      { label: 'Poetry',  href: '/poetry' },
    ],
  },
  {
    label: 'Visual Art',
    children: [
      { label: 'Paintings',                href: '/visual-art/paintings' },
      { label: 'Collages & Mixed Media',   href: '/visual-art/collages' },
      { label: 'Handmade Journals & Books',href: '/visual-art/journals' },
      { label: 'Art Talk',                 href: '/visual-art/art-talk' },
    ],
  },
  { label: 'About',   href: '/about' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
function isActive(href?: string, children?: {href:string}[]) {
  if (href) return currentPath === href || currentPath.startsWith(href + '/');
  if (children) return children.some(c => currentPath.startsWith(c.href));
  return false;
}
---

<header class="bg-site-bg border-b border-light-bg sticky top-0 z-50 shadow-sm">
  <div class="max-w-6xl mx-auto px-4 flex items-center justify-between h-16">

    <!-- Site title / logo -->
    <a href="/" class="font-heading text-xl font-medium text-site-text hover:text-accent transition-colors">
      HL Gaydos
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
      <a href="/"
        class={`px-3 py-2 text-sm font-medium rounded transition-colors
          ${isActive('/') && currentPath === '/' ? 'text-accent' : 'text-site-text hover:text-accent'}`}>
        Home
      </a>

      {navItems.map(item => (
        item.children ? (
          <div class="relative group">
            <button
              class={`px-3 py-2 text-sm font-medium rounded transition-colors flex items-center gap-1
                ${isActive(undefined, item.children) ? 'text-accent' : 'text-site-text hover:text-accent'}`}
              aria-haspopup="true"
            >
              {item.label}
              <svg class="w-3 h-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div class="absolute top-full right-0 mt-1 w-52 bg-white shadow-lg rounded border border-light-bg
                        opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150">
              {item.children.map(child => (
                <a href={child.href}
                   class={`block px-4 py-2.5 text-sm transition-colors
                     ${currentPath.startsWith(child.href)
                       ? 'bg-light-bg text-accent font-medium'
                       : 'text-site-text hover:bg-light-bg hover:text-accent'}`}>
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a href={item.href}
            class={`px-3 py-2 text-sm font-medium rounded transition-colors
              ${isActive(item.href) ? 'text-accent' : 'text-site-text hover:text-accent'}`}>
            {item.label}
          </a>
        )
      ))}
    </nav>

    <!-- Mobile hamburger -->
    <button id="menu-btn" class="md:hidden p-2 rounded text-site-text hover:text-accent" aria-label="Toggle menu" aria-expanded="false">
      <svg id="icon-open"  class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
      <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-site-bg border-t border-light-bg">
    <nav class="max-w-6xl mx-auto px-4 py-3 flex flex-col gap-1" aria-label="Mobile navigation">
      <a href="/" class="px-3 py-2 text-sm font-medium text-site-text hover:text-accent rounded hover:bg-light-bg">Home</a>

      {navItems.map(item => (
        item.children ? (
          <div>
            <p class="px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-accent2 mt-2">{item.label}</p>
            {item.children.map(child => (
              <a href={child.href}
                 class="block px-5 py-2 text-sm text-site-text hover:text-accent hover:bg-light-bg rounded">
                {child.label}
              </a>
            ))}
          </div>
        ) : (
          <a href={item.href}
             class="px-3 py-2 text-sm font-medium text-site-text hover:text-accent rounded hover:bg-light-bg">
            {item.label}
          </a>
        )
      ))}
    </nav>
  </div>
</header>

<script>
  const btn   = document.getElementById('menu-btn');
  const menu  = document.getElementById('mobile-menu');
  const open  = document.getElementById('icon-open');
  const close = document.getElementById('icon-close');
  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
    open?.classList.toggle('hidden');
    close?.classList.toggle('hidden');
  });
</script>
