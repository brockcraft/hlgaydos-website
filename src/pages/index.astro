---
import SiteLayout from '../layouts/SiteLayout.astro';

const featuredPaintings = [
  { src: '/images/paintings/Chrysalis.jpg',             alt: 'Chrysalis' },
  { src: '/images/paintings/In-Search-of-Numinous.jpg', alt: 'In Search of the Numinous' },
  { src: '/images/paintings/Wild-Geese.jpg',            alt: 'Wild Geese' },
  { src: '/images/paintings/The-Grace-of-an-Ordinary-Day.jpg', alt: 'The Grace of an Ordinary Day' },
  { src: '/images/paintings/Memories-Have-Open-Spaces.jpg',    alt: 'Memories Have Open Spaces' },
  { src: '/images/paintings/Listening-Alone.jpg',       alt: 'Listening Alone' },
];

const reviews = [
  { text: '&ldquo;&hellip;eloquent and warm&hellip;&rdquo;' },
  { text: '&ldquo;A thoughtful, winding reflection that gently challenges readers to recognize the patterns of their own lives.&rdquo;', source: 'Kirkus Reviews' },
  { text: '&ldquo;&hellip;a compelling and straightforward voice&hellip;this book is essential reading for those interested in spirituality, self-transformation, and art.&rdquo;' },
  { text: '&ldquo;&hellip;a master at evoking time and place.&rdquo;', source: 'Erica Ball, Independent Book Review' },
];
---
<SiteLayout
  title="HL Gaydos"
  description="Author and visual artist. Writer of spiritual memoir and poetry; painter and maker of collages and handmade books."
>

  <!-- Hero -->
  <section class="bg-site-bg py-16 md:py-24">
    <div class="max-w-6xl mx-auto px-4 grid md:grid-cols-2 gap-12 items-center">
      <div>
        <h1 class="font-heading text-4xl md:text-5xl font-light text-site-text mb-6 leading-tight">
          HL Gaydos
        </h1>
        <p class="text-lg text-site-text/80 leading-relaxed mb-8">
          Author and visual artist exploring the paradoxes, ambiguities, and hidden
          dimensions of ordinary human experience — through memoir, poetry, painting,
          and handmade art.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/books"
             class="inline-block bg-accent text-white font-medium px-6 py-3 rounded hover:bg-accent/90 transition-colors">
            Books
          </a>
          <a href="/visual-art/paintings"
             class="inline-block border border-accent text-accent font-medium px-6 py-3 rounded hover:bg-accent hover:text-white transition-colors">
            Visual Art
          </a>
        </div>
      </div>
      <div class="flex justify-center">
        <img
          src="/images/books/Gaydos-Cover-Project-front-jpg.jpg"
          alt="Book cover — A Creative Journey"
          class="max-w-xs w-full shadow-2xl rounded"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="max-w-6xl mx-auto px-4">
    <hr class="border-light-bg" />
  </div>

  <!-- Reviews -->
  <section class="py-14 bg-light-bg">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="font-heading text-2xl font-light text-site-text mb-10 tracking-wide uppercase text-sm">
        What Readers Are Saying
      </h2>
      <div class="grid md:grid-cols-2 gap-6">
        {reviews.map(r => (
          <blockquote class="bg-white rounded p-6 shadow-sm text-left">
            <p class="text-site-text/90 italic leading-relaxed" set:html={r.text} />
            {r.source && (
              <footer class="mt-3 text-sm font-medium text-accent">— {r.source}</footer>
            )}
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Paintings -->
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex items-center justify-between mb-8">
        <h2 class="font-heading text-2xl font-light text-site-text">Selected Paintings</h2>
        <a href="/visual-art/paintings" class="text-sm text-accent hover:underline font-medium">View all &rarr;</a>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
        {featuredPaintings.map(p => (
          <a href="/visual-art/paintings" class="group block overflow-hidden rounded shadow-sm hover:shadow-md transition-shadow">
            <img
              src={p.src}
              alt={p.alt}
              class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- About snippet -->
  <section class="py-14 bg-light-bg">
    <div class="max-w-4xl mx-auto px-4 grid md:grid-cols-3 gap-10 items-center">
      <div class="flex justify-center">
        <img
          src="/images/author/Gaydos-author-photo.jpg"
          alt="HL Gaydos"
          class="w-48 h-48 object-cover rounded-full shadow-md"
          loading="lazy"
        />
      </div>
      <div class="md:col-span-2">
        <h2 class="font-heading text-2xl font-light text-site-text mb-4">About HL Gaydos</h2>
        <p class="text-site-text/80 leading-relaxed mb-5">
          My creative work as both writer and visual artist focuses on the experience of
          being human in a complex world filled with uncertainty and possibility.
          Metaphor is my principal tool and beauty is my aim.
        </p>
        <a href="/about" class="text-sm text-accent hover:underline font-medium">Read more &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Writing links -->
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h2 class="font-heading text-2xl font-light text-site-text mb-10">Writing</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <a href="/books"
           class="block p-8 bg-white border border-light-bg rounded hover:shadow-md transition-shadow group">
          <div class="text-3xl mb-3">📖</div>
          <h3 class="font-heading text-xl font-medium text-site-text group-hover:text-accent transition-colors mb-2">Books</h3>
          <p class="text-sm text-site-text/70">Spiritual memoir exploring grace, gratitude, and the creative life.</p>
        </a>
        <a href="/essays"
           class="block p-8 bg-white border border-light-bg rounded hover:shadow-md transition-shadow group">
          <div class="text-3xl mb-3">✍️</div>
          <h3 class="font-heading text-xl font-medium text-site-text group-hover:text-accent transition-colors mb-2">Essays</h3>
          <p class="text-sm text-site-text/70">Reflections on art, memory, and the ordinary extraordinary.</p>
        </a>
        <a href="/poetry"
           class="block p-8 bg-white border border-light-bg rounded hover:shadow-md transition-shadow group">
          <div class="text-3xl mb-3">🌿</div>
          <h3 class="font-heading text-xl font-medium text-site-text group-hover:text-accent transition-colors mb-2">Poetry</h3>
          <p class="text-sm text-site-text/70">Poems that sit at the edge of what can and cannot be said.</p>
        </a>
      </div>
    </div>
  </section>

</SiteLayout>
