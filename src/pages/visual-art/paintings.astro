  { src: '/images/paintings/Wild-Geese.jpg',                     title: 'Wild Geese' },
  { src: '/images/paintings/The-Grace-of-an-Ordinary-Day.jpg',   title: 'The Grace of an Ordinary Day' },
  { src: '/images/paintings/Memories-Have-Open-Spaces.jpg',      title: 'Memories Have Open Spaces' },
  { src: '/images/paintings/Listening-Alone.jpg',                title: 'Listening Alone' },
  { src: '/images/paintings/Grace.jpg',                          title: 'Grace' },
